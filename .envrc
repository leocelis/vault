# direnv: auto-activate the project-scoped Rust toolchain on `cd` (see CONTRIBUTING.md).
# Run `direnv allow` once. Requires ./scripts/setup-rust.sh to have been run.
# Nothing here is machine-wide — RUSTUP_HOME / CARGO_HOME live in ./.toolchain (git-ignored).
export RUSTUP_HOME="$PWD/.toolchain/rustup"
export CARGO_HOME="$PWD/.toolchain/cargo"
if [ -d "$CARGO_HOME/bin" ]; then
  PATH_add "$CARGO_HOME/bin"
else
  log_status "vault: run ./scripts/setup-rust.sh to install the project-scoped toolchain"
fi
